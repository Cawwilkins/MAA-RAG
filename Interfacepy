class HybridRetriever(BaseRetriever):
    """
    Sync-only hybrid retriever:
    - runs vector retriever + BM25 retriever
    - merges + dedupes results
    - returns top_k combined candidates (keeps original scores as-is)
    """
    def __init__(self, vec_retriever, bm25_retriever, similarity_top_k: int = 10):
        super().__init__()
        self._vec = vec_retriever
        self._bm25 = bm25_retriever
        self._top_k = similarity_top_k

    def _dedupe(self, nodes: List[NodeWithScore]) -> List[NodeWithScore]:
        seen: Set[str] = set()
        out: List[NodeWithScore] = []

        for nws in nodes:
            node = getattr(nws, "node", nws)

            # Best-effort stable ID
            nid = (
                getattr(node, "node_id", None)
                or getattr(node, "id_", None)
                or getattr(nws, "id_", None)
                or None
            )

            # Fallback to content hash if no id exists
            if nid is None:
                text = getattr(node, "text", "") or (node.get_content() if hasattr(node, "get_content") else "")
                nid = str(hash(text))

            if nid in seen:
                continue
            seen.add(nid)
            out.append(nws)

        return out

    def _retrieve(self, query_bundle: QueryBundle) -> List[NodeWithScore]:
        q = query_bundle.query_str

        vec_nodes = self._vec.retrieve(q)
        bm25_nodes = self._bm25.retrieve(q)

        merged = self._dedupe(vec_nodes + bm25_nodes)
        return merged[: self._top_k]


