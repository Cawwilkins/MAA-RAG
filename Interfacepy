# Loads index from vector dB and creates it if it doesn't exist
def load_index():
    storage_dir = Path(db_dir) / "storage"

    if not storage_dir.exists():
        print("No vector db found, creating a new one...")
        index = create_index()
        return load_index()
    else:
        print("Loading existing vector db...")
        print("Creating vector store...")
        client = qdrant_client.QdrantClient(path=db_dir)
        vector_store = QdrantVectorStore(client=client, collection_name="test_store")
        storage_context = StorageContext.from_defaults(
            vector_store=vector_store,
            persist_dir=str(Path(db_dir) / "storage"),   # <-- must match your build path
        )
        index = load_index_from_storage(storage_context)
    return index


# Initializes the query engine with the index
def initialize_query_engine(index):
    vec = VectorIndexRetriever(
        index=index,
        similarity_top_k=10,                      # widen for recall
        embed_model=Settings.embed_model,
    )
    
    docstore = index.storage_context.docstore

    bm25 = BM25Retriever.from_defaults(docstore=docstore, similarity_top_k=10)   # BM25 for additional context

    node_posts = [
        #SimilarityPostprocessor(similarity_cutoff=0.2, min_nodes=1),  # ensure some nodes
        reranker,
        LongContextReorder(),
    ]

    hybrid = HybridRetriever(vec_retriever=vec, bm25_retriever=bm25, similarity_top_k=10)

    synthesizer = get_response_synthesizer(
        llm=Settings.llm,
        text_qa_template=qa_template,
        response_mode="compact",
    )

    query_engine = RetrieverQueryEngine(
        retriever=hybrid,
        response_synthesizer=synthesizer,
        node_postprocessors=node_posts,
    )
    return query_engine


# Asks a question using the query engine
def ask_question(query_engine, question: str):
    if not question:
        print("> MAA Assistant: Please provide a question.")
        return
    question = question.strip()
    nodes = query_engine.retriever.retrieve(question)

    if not nodes:
        print("> MAA Assistant: No relevant results found.")
        return

    print(f"[DEBUG] Retrieved {len(nodes)} nodes")
    for i, n in enumerate(nodes[:2]):
        node_obj = getattr(n, "node", n)
        text = getattr(node_obj, "text", "") or (node_obj.get_content() if hasattr(node_obj, "get_content") else "")
        print(f"[Node {i}] {text[:200]!r}")

    response = query_engine.query(question)

    if response:
        print(f"> MAA Assistant: {response}")
        return
    else:
        print("> MAA Assistant: Sorry, I don't have an answer for that")
        return


